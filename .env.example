# ════════════════════════════════════════════
#  AYIHA BOOST BEN/AFRICA — Variables d'environnement
# ════════════════════════════════════════════

# ═══ Chatbot AI ═══
# Clé API Google Gemini (gratuite sur https://aistudio.google.com)
# Sans cette clé, le chatbot fonctionne en mode local (réponses prédéfinies)
VITE_GEMINI_API_KEY=AIzaSy_VOTRE_CLE_ICI

# ═══ Service d'Email ═══
# Provider: 'emailjs', 'formspree', ou 'fallback' (simulation)
VITE_EMAIL_PROVIDER=fallback

# Option 1: EmailJS (gratuit jusqu'à 200 emails/mois)
# Créez un compte sur https://www.emailjs.com/
VITE_EMAILJS_PUBLIC_KEY=VOTRE_PUBLIC_KEY
VITE_EMAILJS_SERVICE_ID=VOTRE_SERVICE_ID
VITE_EMAILJS_CONTACT_TEMPLATE=contact_template
VITE_EMAILJS_JOIN_TEMPLATE=join_template

# Option 2: Formspree (gratuit jusqu'à 50 submissions/mois)
# Créez un endpoint sur https://formspree.io/
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/VOTRE_ID

# ═══ Authentification ═══
# Provider: 'supabase' ou 'local' (simulation)
VITE_AUTH_PROVIDER=local

# Supabase (recommandé pour la production)
# Créez un projet sur https://supabase.com
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_CLE_ANON
